<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Inherit the main Odoo invoice report -->
        <template id="report_bill_invoice_inherit" inherit_id="account.report_invoice_document">
            <xpath expr="//div[@class='page']" position="replace">
                <div class="page" style="padding-top: 0px !important; margin-top: 3px !important;">

                    <!-- Header -->
                    <div style="text-align: center; font-weight: bold; font-size: 20px; margin-bottom: 10px;">
                        <u>Invoice / Bill</u>
                    </div>

                    <div class="row" style="margin-top: 10px;">

                        <!-- Left section: Customer & billing -->
                        <div class="col-6" style="text-align: left;">
                            <strong>Invoice No:</strong> <span t-field="o.name"/><br/>
                            <strong>Customer Name:</strong> <span t-field="o.partner_id.name"/><br/>
                            <strong>Billing Address:</strong><br/>
                            <span t-esc="o.partner_id.street"/>
                            <t t-if="o.partner_id.street2">
                                <span t-esc="o.partner_id.street2"/>
                            </t><br/>
                            <span t-esc="o.partner_id.city"/>
                            <t t-if="o.partner_id.zip"> - <span t-esc="o.partner_id.zip"/></t><br/>
                            <t t-if="o.partner_id.country_id">
                                <span t-esc="o.partner_id.country_id.name"/>
                            </t><br/>
                            <strong>Phone No:</strong> <span t-field="o.partner_id.phone"/><br/>
                            <strong>Delivery Address:</strong><br/>
                            <span t-esc="o.partner_shipping_id.name"/><br/>
                            <span t-esc="o.partner_shipping_id.street"/>
                            <t t-if="o.partner_shipping_id.street2"><span t-esc="o.partner_shipping_id.street2"/></t><br/>
                            <span t-esc="o.partner_shipping_id.city"/>
                            <t t-if="o.partner_shipping_id.zip"> - <span t-esc="o.partner_shipping_id.zip"/></t><br/>
                            <t t-if="o.partner_shipping_id.country_id"><span t-esc="o.partner_shipping_id.country_id.name"/></t><br/>
                            <strong>Delivery Date:</strong> <span t-field="o.delivery_date"/>
                        </div>

                        <!-- Right section: Sales & warehouse -->
                        <div class="col-6" style="text-align: left;">
                            <strong>Order / PO No:</strong>
                            <span t-esc="', '.join(sorted(set(['%s' % rec.name for rec in o.invoice_line_ids.mapped('sale_line_ids.order_id')])))"/><br/>
                            <strong>Order Date:</strong>
                            <span t-esc="', '.join([d.strftime('%Y-%m-%d') for d in o.invoice_line_ids.mapped('sale_line_ids.order_id.date_order') if d])"/><br/>
                            <strong>Salesperson:</strong> <span t-field="o.employee_id.name"/><br/>
                            <strong>Phone:</strong> <span t-field="o.employee_id.work_phone"/><br/>
                            <strong>Current Outstanding:</strong> <span t-field="o.partner_id.credit"/><br/>
                            <strong>Delivery Warehouse:</strong>
                            <t t-set="warehouse_names" t-value="[]"/>
                            <t t-foreach="o.invoice_line_ids.mapped('sale_line_ids.order_id.picking_ids').filtered(lambda p: p.picking_type_id.code == 'outgoing')" t-as="picking">
                                <t t-if="picking.location_id.warehouse_id.name">
                                    <t t-set="warehouse_names" t-value="warehouse_names + [picking.location_id.warehouse_id.name]"/>
                                </t>
                            </t>
                            <t t-esc="', '.join(sorted(set(warehouse_names)))"/><br/>
                            <strong>Delivered By:</strong> <span t-field="o.delivered_by.name"/>
                        </div>

                    </div>

                    <br/>

                    <!-- Invoice Lines Table -->
                    <table class="table" style="width: 100%; border-collapse: collapse; background-color: white;">
                        <thead>
                            <tr>
                                <th>Sl. #</th>
                                <th>P. Type</th>
                                <th>Product Description</th>
                                <th>MRP (Tk)</th>
                                <th>Qty Pcs</th>
                                <th>Com. %</th>
                                <th>Gross Value (Tk)</th>
                                <th>Com. Amount (Tk)</th>
                                <th>N. Value (Tk)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.invoice_line_ids" t-as="line_id" t-foreach-index="line_id_index">
                                <td t-esc="line_id_index + 1"/>
                                <td t-esc="line_id.product_id.categ_id.name"/>
                                <td>
                                    <t t-if="line_id.product_id.default_code">[<t t-esc="line_id.product_id.default_code"/>] - </t>
                                    <t t-esc="line_id.product_id.name"/>
                                    <t t-if="line_id.product_id.product_template_attribute_value_ids">
                                        - [<t t-esc="', '.join(line_id.product_id.product_template_attribute_value_ids.mapped('name'))"/>]
                                    </t>
                                </td>
                                <td t-esc="line_id.price_unit"/>
                                <td t-esc="line_id.quantity"/>
                                <td t-esc="line_id.discount"/>
                                <td t-set="gross_value" t-value="line_id.price_unit * line_id.quantity"/>
                                <td t-esc="gross_value"/>
                                <td t-set="commission_amount" t-value="gross_value * (line_id.discount / 100)"/>
                                <td t-esc="'%.2f' % (gross_value - commission_amount - (line_id.additional_discount or 0))"/>
                            </tr>
                        </tbody>
                    </table>

                    <!-- Total in words -->
                    <div style="margin-top: 10px;">
                        <strong>In Words:</strong>
                        <span t-esc="env['account.move'].number_to_words(str(sum((l.price_unit * l.quantity - (l.price_unit * l.quantity * l.discount / 100) - (l.additional_discount or 0)) for l in o.invoice_line_ids))) + ' Only'"/>
                    </div>

                    <br/>
                    <!-- Signature Section -->
                    <div class="row" style="margin-top: 20px;">
                        <div class="col-4" style="text-align: center;">
                            __________________________<br/>Prepared by
                        </div>
                        <div class="col-4" style="text-align: center;">
                            __________________________<br/>Checked by
                        </div>
                        <div class="col-4" style="text-align: center;">
                            __________________________<br/>Received by
                        </div>
                    </div>

                </div>
            </xpath>
        </template>
    </data>
</odoo>