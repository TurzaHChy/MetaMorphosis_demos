<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="report_bill_invoice_inherit" inherit_id="account.report_invoice_document">
            <xpath expr="." position="replace">
                <t t-call="web.external_layout">
                    <t t-set="o" t-value="o.with_context(lang=lang)"/>
                    <t t-set="print_date" t-value="datetime.datetime.now()"/>
                    <div class="page" style="padding-top: 0px !important; margin-top: 3px !important; color: black !important; font-family: sans-serif;">
                        
                        <!-- Header / Title -->
                        <div class="row">
                            <div class="col-12 text-center">
                                <h1 style="font-weight: bold; font-size: 28px; margin-bottom: 20px; color: black !important;">Invoice/Bill</h1>
                            </div>
                        </div>

                        <!-- Info Section -->
                        <div class="row mt-2" style="font-size: 13px;">
                            <!-- Left Column -->
                            <div class="col-6">
                                <div class="row">
                                    <div class="col-5"><strong>Invoice No.:</strong></div>
                                    <div class="col-7"><span t-field="o.name"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-5"><strong>Customer Name :</strong></div>
                                    <div class="col-7"><span t-field="o.partner_id.name"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-5"><strong>Billing Address:</strong></div>
                                    <div class="col-7">
                                        <span t-field="o.partner_id.city"/>
                                    </div>
                                </div>
                                <br/>
                                <div class="row">
                                    <div class="col-5"><strong>Bangladesh Phone No. :</strong></div>
                                    <div class="col-7"><span t-field="o.partner_id.phone"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-5"><strong>Delivery Address :</strong></div>
                                    <div class="col-7"><span t-field="o.partner_shipping_id.city"/></div>
                                </div>
                                <br/>
                                <div class="row">
                                    <div class="col-5"><strong>Bangladesh Phone No. :</strong></div>
                                    <div class="col-7"><span t-field="o.partner_shipping_id.phone"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-5"><strong>Delivery Date :</strong></div>
                                    <div class="col-7"><span t-field="o.invoice_date"/></div>
                                </div>
                            </div>

                            <!-- Right Column -->
                            <div class="col-6">
                                <div class="row">
                                    <div class="col-6 text-right"><strong>Order No. / PO No.:</strong></div>
                                    <div class="col-6"><span t-field="o.invoice_origin"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-6 text-right"><strong>Order Date:</strong></div>
                                    <div class="col-6"><span t-field="o.invoice_date"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-6 text-right"><strong>Name of Salesman:</strong></div>
                                    <div class="col-6"><span t-field="o.user_id.name"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-6 text-right"><strong>Phone No.:</strong></div>
                                    <div class="col-6"><span t-field="o.user_id.partner_id.phone"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-6 text-right"><strong>Current Outstanding:</strong></div>
                                    <div class="col-6"><span t-field="o.partner_id.credit"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-6 text-right"><strong>Delivery Warehouse:</strong></div>
                                    <div class="col-6">
                                        <span>Classic Mart</span>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-6 text-right"><strong>Delivered By:</strong></div>
                                    <div class="col-6"><span t-field="o.user_id.name"/></div>
                                </div>
                            </div>
                        </div>

                        <!-- Main Table -->
                        <table class="table table-bordered mt-4" style="border: 1px solid black !important; font-size: 11px; width: 100%;">
                            <thead>
                                <tr style="background-color: white;">
                                    <th class="text-center" style="border: 1px solid black !important;">SL. #</th>
                                    <th class="text-center" style="border: 1px solid black !important;">P. TYPE</th>
                                    <th class="text-center" style="border: 1px solid black !important;">PRODUCT DESCRIPTION</th>
                                    <th class="text-center" style="border: 1px solid black !important;">MRP (TK)</th>
                                    <th class="text-center" style="border: 1px solid black !important;">QTY PCS</th>
                                    <th class="text-center" style="border: 1px solid black !important;">COM%</th>
                                    <th class="text-center" style="border: 1px solid black !important;">GROSS VALUE (TK)</th>
                                    <th class="text-center" style="border: 1px solid black !important;">COM. AMOUNT. (TK)</th>
                                    <th class="text-center" style="border: 1px solid black !important;">N. VALUE (TK)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="sl_no" t-value="1"/>
                                <t t-set="total_net" t-value="0.0"/>
                                <tr t-foreach="o.invoice_line_ids" t-as="line">
                                    <td class="text-center" style="border: 1px solid black !important;"><span t-esc="sl_no"/><t t-set="sl_no" t-value="sl_no + 1"/></td>
                                    <td class="text-center" style="border: 1px solid black !important;"><span t-field="line.product_id.categ_id.name"/></td>
                                    <td style="border: 1px solid black !important;">
                                        <span t-field="line.product_id.name"/>
                                    </td>
                                    <td class="text-right" style="border: 1px solid black !important;"><span t-field="line.price_unit"/></td>
                                    <td class="text-center" style="border: 1px solid black !important;"><span t-field="line.quantity"/></td>
                                    <td class="text-center" style="border: 1px solid black !important;"><span t-field="line.discount"/></td>
                                    <td class="text-right" style="border: 1px solid black !important;">
                                        <t t-set="gross" t-value="line.price_unit * line.quantity"/>
                                        <span t-esc="'%.1f' % gross"/>
                                    </td>
                                    <td class="text-right" style="border: 1px solid black !important;">
                                        <t t-set="comm" t-value="gross * (line.discount / 100.0)"/>
                                        <span t-esc="'%.2f' % comm"/>
                                    </td>
                                    <td class="text-right" style="border: 1px solid black !important;">
                                        <t t-set="net" t-value="line.price_subtotal"/>
                                        <span t-esc="'%.1f' % net"/>
                                        <t t-set="total_net" t-value="total_net + net"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="8" class="text-center" style="border: 1px solid black !important;"><strong>Total</strong></td>
                                    <td class="text-right" style="border: 1px solid black !important;">
                                        <strong t-esc="'%.1f' % total_net"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Amount in Words -->
                        <div class="mt-2" style="font-size: 13px;">
                            <strong>In word:</strong> <span t-esc="o.currency_id.amount_to_text(total_net)"/>
                            <br/>
                            <strong>Printing Date:</strong> <span t-esc="print_date.strftime('%d-%m-%Y - %I:%M:%S %p')"/>
                        </div>

                        <!-- Footer / Signatures -->
                        <div class="row" style="margin-top: 60px;">
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid black; width: 60%; margin: 0 auto;"></div>
                                <strong>Prepared by</strong><br/>
                                <span style="font-size: 12px;">Name:</span><br/>
                                <span style="font-size: 12px;">Signature:</span>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid black; width: 60%; margin: 0 auto;"></div>
                                <strong>Checked by</strong><br/>
                                <span style="font-size: 12px;">Name:</span><br/>
                                <span style="font-size: 12px;">Signature:</span>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top: 1px solid black; width: 60%; margin: 0 auto;"></div>
                                <strong>Received by</strong><br/>
                                <span style="font-size: 12px;">Name:</span><br/>
                                <span style="font-size: 12px;">Signature:</span>
                            </div>
                        </div>

                        <!-- Technical Hooks (Hidden) -->
                        <div id="qrcode" style="display: none;"/>
                        <p name="payment_communication" style="display: none;">
                            <t t-if="o.partner_bank_id"/>
                        </p>
                    </div>
                </t>
            </xpath>
        </template>
    </data>
</odoo>
