<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <template id="report_saleorder_document_inherit_arrival"
              inherit_id="sale.report_saleorder_document">


        <!-- 1. Add "Arrival" column header after the Quantity header -->
        <xpath expr="//th[@name='th_quantity']" position="after">
            <th name="th_arrival" class="text-end text-nowrap">Arrival</th>
            <th name="th_commission" class="text-end text-nowrap">Commission (%)</th>
        </xpath>

        <!-- 2. Add Arrival value cell after the Quantity cell for each product line -->
        <xpath expr="//td[@name='td_product_quantity']" position="after">
            <td name="td_arrival" class="text-end text-nowrap">
                <span t-field="line.arrival"/>
            </td>
            <td name="td_commission" class="text-end text-nowrap">
                <span t-field="line.commission"/>%
            </td>
        </xpath>

    </template>

</odoo>